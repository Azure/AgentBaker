{
    "type": "Microsoft.VirtualMachineImages",
    "apiVersion": "2025-10-01",
    "location": "<LOCATION>",
    "identity": {
        "type": "UserAssigned",
        "userAssignedIdentities": {
            "<IMAGE_BUILDER_IDENTITY_ID>": {}
        }
    },
    "properties": {
        "source": {
            "type": "<SOURCE_TYPE>",
            "<SOURCE_ID_KEY>": "<SOURCE_ID>"
        },
        "customize": [
            {
                "type": "Shell",
                "name": "Cleanup",
                "inline": [
                    "sudo /bin/bash -eux /opt/azure/containers/cleanup-vhd.sh && sudo rm -f /opt/azure/containers/cleanup-vhd.sh"
                ]
            }
        ],
        "optimize": {
            "vmBoot": {
                "state": "Enabled"
            },
            "workload": {
                "state": "Enabled",
                "scriptUri": "<WORKLOAD_OPTIMIZATION_SCRIPT_URL>"
            }
        },
        "distribute": [
            {
                "type": "VHD",
                "uri": "<VHD_URI>",
                "runOutputName": "VHD"
            }
        ]
    }
}
