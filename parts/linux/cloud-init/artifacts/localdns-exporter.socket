[Unit]
Description=Localdns Prometheus Exporter Socket
Documentation=https://github.com/Azure/AgentBaker

[Socket]
# Bind to all interfaces so vmagent can scrape via the node's InternalIP.
# CSE may override this with a node-IP-specific drop-in for tighter binding.
ListenStream=0.0.0.0:9353
# Accept=yes means "Spawn a new service instance for every connection"
# This enables on-demand execution: the exporter script only runs when VMAgent scrapes
Accept=yes

[Install]
WantedBy=sockets.target
