#!/bin/sh

set -e

# Enumerate kernels directly from /boot (AzureLinux 10_linux does not
# export reverse_sorted_list like Ubuntu's does).
HWE=
OTHER=

for linux in /boot/vmlinuz-*; do
	[ -f "$linux" ] || continue
	version="${linux#/boot/vmlinuz-}"
	major=$(echo "$version" | cut -d. -f1)
	case $major in
		6) minor=$(echo "$version" | cut -d. -f2)
		   if [ "$minor" -ge 12 ]; then
			: "${HWE:="$version"}"
		   else
			: "${OTHER:="$version"}"
		   fi
		   ;;
		*) : "${OTHER:="$version"}" ;;
	esac
done

if [ -z "${HWE}" ] || [ -z "${OTHER}" ]; then
	echo "Only one kernel variant (HWE or standard) found" >&2
	exit 0
fi

# Get boot_device_id (root partition UUID) from existing grub.cfg menuentry IDs.
boot_device_id=$(grep -m1 -o 'gnulinux-[^"]*-advanced-[a-f0-9-]*' /boot/grub2/grub.cfg 2>/dev/null | sed 's/.*-advanced-//')

if [ -z "$boot_device_id" ]; then
	echo "Could not determine boot_device_id" >&2
	exit 0
fi

echo "Default HWE: ${HWE}, standard: ${OTHER}, boot_device_id: ${boot_device_id}" >&2

cat << EOF
insmod smbios
smbios --type 4 --get-string 7 --set cpu_manufacturer

if [ x\$cpu_manufacturer = xNVIDIA ]; then
	set default="gnulinux-${HWE}-advanced-${boot_device_id}"
	set nvidia_args="iommu.passthrough=1 irqchip.gicv3_nolpi=y arm_smmu_v3.disable_msipolling=1"
else
	set default="gnulinux-${OTHER}-advanced-${boot_device_id}"
fi
EOF
